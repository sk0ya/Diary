<Window x:Class="Diary.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diary — 設定"
        Width="440"
        Height="195"
        MinWidth="360"
        MinHeight="160"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush"      Color="#080F1C" />
        <SolidColorBrush x:Key="StrokeBrush"     Color="#1C2E42" />
        <SolidColorBrush x:Key="AccentBrush"     Color="#E0926E" />
        <SolidColorBrush x:Key="TextBrush"       Color="#E2EAF4" />
        <SolidColorBrush x:Key="TextSubtleBrush" Color="#3D5468" />

        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="40"
                          ShadowDepth="12"
                          Direction="270"
                          Color="#000000"
                          Opacity="0.70" />

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="#0B1420" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="8,5" />
            <Setter Property="FontFamily"      Value="Cascadia Code" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="CaretBrush"      Value="{StaticResource AccentBrush}" />
            <Setter Property="SelectionBrush"  Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="BrowseButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{StaticResource TextSubtleBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="8,5" />
            <Setter Property="FontFamily"      Value="Cascadia Code" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#12E0926E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="24"
            Background="{StaticResource ShellBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Padding="18,12"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#101E30" Offset="0" />
                        <GradientStop Color="#0B1623" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="設定"
                               FontFamily="Yu Gothic UI Semibold"
                               FontSize="14"
                               Foreground="{StaticResource TextBrush}" />
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Cascadia Code"
                            FontSize="11"
                            Foreground="{StaticResource TextSubtleBrush}"
                            Cursor="Hand"
                            Opacity="0.6"
                            Click="CloseButton_Click"
                            FocusVisualStyle="{x:Null}" />
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="18,14,18,16" VerticalAlignment="Center">

                <!-- Folder -->
                <TextBlock Text="保存フォルダ"
                           FontFamily="Yu Gothic UI"
                           FontSize="11"
                           Foreground="{StaticResource TextSubtleBrush}"
                           Margin="0,0,0,5" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FolderTextBox"
                             Grid.Column="0"
                             Style="{StaticResource InputStyle}" />
                    <Button Grid.Column="2"
                            Style="{StaticResource BrowseButtonStyle}"
                            Content="参照..."
                            Click="BrowseButton_Click" />
                </Grid>

                <!-- Always visible -->
                <CheckBox x:Name="AlwaysVisibleCheckBox"
                          Margin="0,12,0,0"
                          Foreground="{StaticResource TextBrush}"
                          FontFamily="Yu Gothic UI"
                          FontSize="12"
                          Cursor="Hand">
                    <TextBlock Text="常に表示する（フォーカスを失っても隠さない）"
                               FontFamily="Yu Gothic UI"
                               FontSize="12"
                               Foreground="{StaticResource TextBrush}" />
                </CheckBox>
            </StackPanel>
        </Grid>
    </Border>
</Window>
