<Window x:Class="Dialy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:editor="clr-namespace:Editor.Controls;assembly=Editor.Controls"
        mc:Ignorable="d"
        Title="Dialy"
        Width="420"
        Height="860"
        MinWidth="340"
        MinHeight="560"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#071019" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0E1926" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#22354A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#DA8A67" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="TextSubtleBrush" Color="#8EA0B6" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#143124" />
        <SolidColorBrush x:Key="WarningBrush" Color="#3A261C" />
    </Window.Resources>

    <Border Margin="12"
            Padding="12"
            Background="{StaticResource ShellBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="14,14,14,10"
                    Background="{StaticResource PanelBrush}"
                    CornerRadius="14"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <StackPanel>
                    <TextBlock Text="Dialy"
                               FontFamily="Cascadia Code"
                               FontSize="11"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock x:Name="EntryDateText"
                               Margin="0,6,0,0"
                               FontFamily="Yu Gothic UI Semibold"
                               FontSize="22"
                               Foreground="{StaticResource TextBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,10,0,10"
                    Padding="12,10"
                    Background="{StaticResource PanelBrush}"
                    CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="LastSavedText"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSubtleBrush}"
                               Text="保存待ち" />
                    <Border x:Name="StateBadge"
                            Grid.Column="1"
                            Padding="8,4"
                            Background="{StaticResource SuccessBrush}"
                            CornerRadius="999">
                        <TextBlock x:Name="StateBadgeText"
                                   FontSize="11"
                                   Foreground="{StaticResource TextBrush}"
                                   Text="保存済み" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="#09131D"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <editor:VimEditorControl x:Name="EditorHost" />
            </Border>
        </Grid>
    </Border>
</Window>
