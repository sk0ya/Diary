<Window x:Class="Dialy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dialy"
        Width="420"
        Height="860"
        MinWidth="340"
        MinHeight="560"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush"       Color="#080F1C" />
        <SolidColorBrush x:Key="PanelBrush"       Color="#0D1828" />
        <SolidColorBrush x:Key="EditorBrush"      Color="#060D18" />
        <SolidColorBrush x:Key="StrokeBrush"      Color="#1C2E42" />
        <SolidColorBrush x:Key="AccentBrush"      Color="#E0926E" />
        <SolidColorBrush x:Key="TextBrush"        Color="#E2EAF4" />
        <SolidColorBrush x:Key="TextSubtleBrush"  Color="#3D5468" />
        <SolidColorBrush x:Key="SuccessBrush"     Color="#4DC88A" />
        <SolidColorBrush x:Key="WarningBrush"     Color="#E87650" />

        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="48"
                          ShadowDepth="16"
                          Direction="270"
                          Color="#000000"
                          Opacity="0.70" />

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"        Value="Transparent" />
            <Setter Property="BorderThickness"   Value="0" />
            <Setter Property="Foreground"        Value="{StaticResource AccentBrush}" />
            <Setter Property="FontFamily"        Value="Cascadia Code" />
            <Setter Property="FontSize"          Value="10" />
            <Setter Property="Opacity"           Value="0.65" />
            <Setter Property="Cursor"            Value="Hand" />
            <Setter Property="Padding"           Value="0,2" />
            <Setter Property="FocusVisualStyle"  Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalDayButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness"  Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Padding"          Value="1,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="hover" CornerRadius="6" Background="Transparent" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsEnabled"   Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="hover" Property="Background" Value="#18E0926E" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer shell — shadow lives here -->
    <Border x:Name="ShellBorder"
            Margin="0"
            Background="{StaticResource ShellBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="20"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0"
                    Padding="16,10,16,10"
                    CornerRadius="20,20,0,0"
                    ClipToBounds="True"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#101E30" Offset="0" />
                        <GradientStop Color="#0B1623" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Button x:Name="EntryDateButton"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            BorderThickness="0"
                            Background="Transparent"
                            Cursor="Hand"
                            Padding="6,3"
                            Margin="-6,-3,0,-3"
                            FocusVisualStyle="{x:Null}"
                            Click="EntryDateButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#18E0926E" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock x:Name="EntryDateText"
                                   FontFamily="Yu Gothic UI Semibold"
                                   FontSize="15"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center" />
                    </Button>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="SettingsButton"
                                BorderThickness="0"
                                FontFamily="Cascadia Code"
                                FontSize="14"
                                Foreground="{StaticResource AccentBrush}"
                                Cursor="Hand"
                                Opacity="0.75"
                                Padding="6,3"
                                FocusVisualStyle="{x:Null}"
                                Click="SettingsButton_Click"
                                Content="⚙">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter TargetName="bg" Property="Background" Value="#18E0926E" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="CloseViewButton"
                                Margin="6,0,0,0"
                                BorderThickness="0"
                                FontFamily="Cascadia Code"
                                FontSize="14"
                                Foreground="{StaticResource TextSubtleBrush}"
                                Cursor="Hand"
                                Opacity="0.75"
                                Padding="6,3"
                                FocusVisualStyle="{x:Null}"
                                Click="CloseViewButton_Click"
                                Content="✕">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter TargetName="bg" Property="Background" Value="#18E87650" />
                                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Accent divider line under header -->
            <Rectangle Grid.Row="0"
                       Height="1"
                       VerticalAlignment="Bottom"
                       Margin="0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="Transparent" Offset="0" />
                        <GradientStop Color="#6E3A22" Offset="0.25" />
                        <GradientStop Color="#6E3A22" Offset="0.75" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Calendar Panel ── -->
            <Border x:Name="CalendarPanel"
                    Grid.Row="1"
                    Visibility="Visible"
                    Margin="0"
                    Padding="12,8,12,6"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>

                    <!-- Month navigation -->
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CalPrevMonthButton"
                                Grid.Column="0"
                                Style="{StaticResource NavButtonStyle}"
                                Content="←"
                                Click="CalPrevMonthButton_Click" />
                        <TextBlock x:Name="CalMonthText"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Cascadia Code"
                                   FontSize="11"
                                   Foreground="{StaticResource TextBrush}" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button x:Name="CalNextMonthButton"
                                    Style="{StaticResource NavButtonStyle}"
                                    Content="→"
                                    Click="CalNextMonthButton_Click" />
                            <Button x:Name="TodayJumpButton"
                                    Style="{StaticResource NavButtonStyle}"
                                    Content="今日"
                                    Margin="0"
                                    Click="TodayJumpButton_Click" />
                        </StackPanel>
                    </Grid>

                    <!-- Day-of-week headers -->
                    <UniformGrid Columns="7" Margin="0">
                        <TextBlock Text="日" HorizontalAlignment="Center" FontFamily="Cascadia Code" FontSize="9" Foreground="{StaticResource TextBrush}" Opacity="0.88" />
                        <TextBlock Text="月" HorizontalAlignment="Center" FontFamily="Cascadia Code" FontSize="9" Foreground="{StaticResource TextBrush}" Opacity="0.88" />
                        <TextBlock Text="火" HorizontalAlignment="Center" FontFamily="Cascadia Code" FontSize="9" Foreground="{StaticResource TextBrush}" Opacity="0.88" />
                        <TextBlock Text="水" HorizontalAlignment="Center" FontFamily="Cascadia Code" FontSize="9" Foreground="{StaticResource TextBrush}" Opacity="0.88" />
                        <TextBlock Text="木" HorizontalAlignment="Center" FontFamily="Cascadia Code" FontSize="9" Foreground="{StaticResource TextBrush}" Opacity="0.88" />
                        <TextBlock Text="金" HorizontalAlignment="Center" FontFamily="Cascadia Code" FontSize="9" Foreground="{StaticResource TextBrush}" Opacity="0.88" />
                        <TextBlock Text="土" HorizontalAlignment="Center" FontFamily="Cascadia Code" FontSize="9" Foreground="{StaticResource TextBrush}" Opacity="0.88" />
                    </UniformGrid>

                    <!-- Day buttons (built in code-behind) -->
                    <UniformGrid x:Name="CalDayGrid" Columns="7" />

                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="14,12,14,12"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <Grid Margin="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="TODO"
                                       FontFamily="Cascadia Code"
                                       FontSize="11"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="TodoSummaryText"
                                       Grid.Column="1"
                                       FontFamily="Cascadia Code"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSubtleBrush}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,10,0" />

                            <TextBox x:Name="TodoInputTextBox"
                                     Grid.Column="2"
                                     Height="32"
                                     Margin="0"
                                     Padding="10,6"
                                     Background="{StaticResource EditorBrush}"
                                     BorderBrush="{StaticResource StrokeBrush}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource TextBrush}"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     FontFamily="Yu Gothic UI"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TodoInputTextBox_KeyDown" />

                            <Button x:Name="TodoAddButton"
                                    Grid.Column="3"
                                    Height="32"
                                    MinWidth="32"
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    Background="#18E0926E"
                                    BorderBrush="{StaticResource StrokeBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource AccentBrush}"
                                    FontFamily="Cascadia Code"
                                    FontSize="14"
                                    Cursor="Hand"
                                    Click="TodoAddButton_Click"
                                    Content="+" />
                        </Grid>

                        <TextBlock x:Name="TodoEmptyText"
                                   Margin="0"
                                   FontFamily="Yu Gothic UI"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSubtleBrush}"
                                   Text="TODO はまだありません" />

                        <ScrollViewer MaxHeight="150"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TodoListPanel" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- ── Editor ── -->
                <Border Grid.Row="2"
                        Background="{StaticResource EditorBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        ClipToBounds="True">
                    <ContentControl x:Name="EditorHostContainer" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
