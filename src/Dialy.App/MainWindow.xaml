<Window x:Class="Dialy.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dialy"
        Width="420"
        Height="860"
        MinWidth="340"
        MinHeight="560"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush"       Color="#080F1C" />
        <SolidColorBrush x:Key="PanelBrush"       Color="#0D1828" />
        <SolidColorBrush x:Key="EditorBrush"      Color="#060D18" />
        <SolidColorBrush x:Key="StrokeBrush"      Color="#1C2E42" />
        <SolidColorBrush x:Key="AccentBrush"      Color="#E0926E" />
        <SolidColorBrush x:Key="TextBrush"        Color="#E2EAF4" />
        <SolidColorBrush x:Key="TextSubtleBrush"  Color="#3D5468" />
        <SolidColorBrush x:Key="SuccessBrush"     Color="#4DC88A" />
        <SolidColorBrush x:Key="WarningBrush"     Color="#E87650" />

        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="48"
                          ShadowDepth="16"
                          Direction="270"
                          Color="#000000"
                          Opacity="0.70" />
    </Window.Resources>

    <!-- Outer shell — shadow lives here -->
    <Border Margin="28"
            Background="{StaticResource ShellBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="20"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0"
                    Padding="20,16,20,16"
                    CornerRadius="20,20,0,0"
                    ClipToBounds="True"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#101E30" Offset="0" />
                        <GradientStop Color="#0B1623" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="DIALY"
                                   FontFamily="Cascadia Code"
                                   FontSize="9"
                                   Foreground="{StaticResource AccentBrush}"
                                   Opacity="0.75" />
                        <TextBlock x:Name="EntryDateText"
                                   Margin="0,5,0,0"
                                   FontFamily="Yu Gothic UI Semibold"
                                   FontSize="21"
                                   Foreground="{StaticResource TextBrush}" />
                    </StackPanel>

                    <!-- Accent badge top-right -->
                    <Border Grid.Column="1"
                            VerticalAlignment="Top"
                            Padding="7,3"
                            CornerRadius="999">
                        <Border.Background>
                            <SolidColorBrush Color="#E0926E" Opacity="0.12" />
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#E0926E" Opacity="0.25" />
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <TextBlock Text="diary"
                                   FontFamily="Cascadia Code"
                                   FontSize="10"
                                   Foreground="{StaticResource AccentBrush}"
                                   Opacity="0.7" />
                    </Border>
                </Grid>
            </Border>

            <!-- Accent divider line under header -->
            <Rectangle Grid.Row="0"
                       Height="1"
                       VerticalAlignment="Bottom"
                       Margin="20,0">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="Transparent" Offset="0" />
                        <GradientStop Color="#6E3A22" Offset="0.25" />
                        <GradientStop Color="#6E3A22" Offset="0.75" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Status bar ── -->
            <Border Grid.Row="1"
                    Margin="12,10,12,10"
                    Padding="14,9"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Colored dot indicator -->
                    <Ellipse x:Name="StatusDot"
                             Grid.Column="0"
                             Width="7" Height="7"
                             Fill="{StaticResource SuccessBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,9,0" />

                    <TextBlock x:Name="LastSavedText"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               FontFamily="Cascadia Code"
                               FontSize="11"
                               Foreground="{StaticResource TextSubtleBrush}"
                               Text="保存待ち" />

                    <TextBlock x:Name="StateBadgeText"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               FontFamily="Cascadia Code"
                               FontSize="11"
                               Foreground="{StaticResource SuccessBrush}"
                               Text="保存済み" />
                </Grid>
            </Border>

            <!-- ── Editor ── -->
            <Border Grid.Row="2"
                    Margin="12,0,12,12"
                    Background="{StaticResource EditorBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    ClipToBounds="True">
                <ContentControl x:Name="EditorHostContainer" />
            </Border>
        </Grid>
    </Border>
</Window>
